{
  "name": "myr-system",
  "version": "1.3.0",
  "description": "Methodological Yield Reports — a pistis-native intelligence compounding system",
  "bin": {
    "myr": "./bin/myr.js"
  },
  "scripts": {
    "store": "node scripts/myr-store.js",
    "search": "node scripts/myr-search.js",
    "weekly": "node scripts/myr-weekly.js",
    "verify": "node scripts/myr-verify.js",
    "keygen": "node scripts/myr-keygen.js",
    "sign": "node scripts/myr-sign.js",
    "export": "node scripts/myr-export.js",
    "import": "node scripts/myr-import.js",
    "synthesize": "node scripts/myr-synthesize.js",
    "test": "node --test 'test/*.test.js'",
    "test:onboarding-truth": "node --test test/onboarding-truth-test.js",
    "test:release": "npm test && npm run test:onboarding-truth",
    "server": "node server/index.js",
    "myr": "node bin/myr.js"
  },
  "dependencies": {
    "@noble/ed25519": "^3.0.0",
    "@noble/hashes": "^2.0.1",
    "better-sqlite3": "^11.8.1",
    "chalk": "^4.1.2",
    "commander": "^13.1.0",
    "express": "^5.2.1",
    "hyperswarm": "^4.17.0"
  }
